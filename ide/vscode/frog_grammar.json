{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "source.frog",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#punctiation" },
    { "include": "#operators" },
    { "include": "#special" },
    { "include": "#literals" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.frog"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(proc|if|else|while|do|end|let)\\b",
          "name": "keyword.control.frog"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(int|bool|ptr)\\b",
          "name": "storage.type.frog"
        }
      ]
    },
    "operators": {
      "patterns": [
        { 
          "match": "@i(8|16|32|64)|@u(8|16|32|64)|!i(8|16|32|64)|!u(8|16|32|64)|\\+|-|\\*|/|%|/%|<<|>>|\\||&|\\^|~|&&|\\|\\||!|==|!=|<=|>=|<|>",
          "name": "keyword.operator.frog"
        }
      ]
    },
    "punctiation": {
      "patterns": [
        {
          "match": "--",
          "name": "punctuation.frog"
        }
      ]
    },
    "special": {
      "patterns": [
        {
          "match": "\\?|\\bputc\\b",
          "name": "support.function"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.frog"
        },
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.frog"
        }
      ]
    }
  }
}
